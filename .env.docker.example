# Bloom2 Docker Compose environment file.
#
# Copy this to `.env.docker` and fill in the values:
#   cp .env.docker.example .env.docker
#
# Then start the stack:
#   docker compose --env-file .env.docker up --build
#
# The --env-file flag makes these variables available for ${} interpolation
# in docker-compose.yml. Without it, GOOGLE_API_KEY will be unset and the
# backend will fail to start.

# Required: Gemini API key from Google AI Studio.
# Get one at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY_HERE

# PostgreSQL password for the bloom user. Defaults to "bloom" if not set.
# Change this if you want a non-default password for the local DB.
# NOTE: this is a local staging environment — the password is only as
# secure as your machine. Real secrets management comes with GCP.
POSTGRES_PASSWORD=bloom

# Host port for the nginx reverse proxy (the single entry point).
# Defaults to 8080. Change this if port 8080 is already in use on your
# machine (e.g. another service). Since this is a build-time arg for the
# frontend and practitioner images, changing it requires a rebuild:
#   docker compose --env-file .env.docker up --build
PROXY_PORT=8080
