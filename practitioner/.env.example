# URL of the Bloom2 FastAPI backend (the practitioner BFF proxies to this).
PRACTITIONER_BACKEND_URL=http://localhost:8000
# The cookie name used for the practitioner session (httpOnly).
PRACTITIONER_COOKIE_NAME=practitioner_session
# Public backend URL exposed to the browser for Socket.io chat connections.
# Defaults to PRACTITIONER_BACKEND_URL. In production, set this to the
# externally-reachable URL of the FastAPI server (the browser connects
# directly with a short-lived WS token — the long-lived bearer never leaves
# the server).
# NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
